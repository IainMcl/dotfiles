<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.screenshot-watch</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__SCRIPT__</string>
    </array>
    <key>WatchPaths</key>
    <array>
        <string>__SCREENSHOTS_DIR__</string>
    </array>
    <key>StandardOutPath</key>
    <string>/tmp/screenshot-watch.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/screenshot-watch.err</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
